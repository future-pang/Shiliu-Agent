# =================================================================
# Emei-Master Project Environment Variables Configuration
# =================================================================
# Instructions:
# 1. Copy this file to .env: `cp .env.example .env`
# 2. Fill in the required API keys and configuration values below.
# =================================================================

# -----------------------------------------------------------------
# 1. LLM & Embedding Model Providers
# -----------------------------------------------------------------

# Volcengine (火山引擎 / Doubao / Ark)
# Used for: Doubao-1.6-flash, deepseek-v3.2 (via Ark), etc.
volcengine_API_KEY=your_volcengine_api_key_here

# Aliyun DashScope (阿里云 / Qwen / DashScope)
# Used for: Qwen models and Aliyun Embeddings (text-embedding-v3).
aliyun_API_KEY=your_aliyun_api_key_here

# (Optional) ARK API Key - used in some specialized tools or legacy scripts
ARK_API_KEY=your_volcengine_api_key_here

# -----------------------------------------------------------------
# 2. Database Configuration
# -----------------------------------------------------------------

# MySQL Configuration
# The password for your MySQL database.
MYSQL_PASSWORD=your_mysql_password_here

# (Optional) Full MySQL Connection URL
# Format: mysql+pymysql://username:password@host:port/database_name
MYSQL_URL=mysql+pymysql://root:your_password@127.0.0.1:3306/emei_master

# Redis Configuration (Used for LangGraph checkpoints and persistence)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------
# 3. Third-Party Tool API Keys (MCP Tools)
# -----------------------------------------------------------------

# QWeather (和风天气) API Key
# Used for: Real-time weather, forecasts, and travel advice.
QWEATHER_API_KEY=your_qweather_api_key_here

# AMAP (高德地图) API Key
# Used for: Geocoding, walking plans, distance measurement, and maps.
AMAP_API_KEY=your_amap_api_key_here

# Tavily (Web Search) API Key
# Used for: Real-time web search capabilities.
TAVILY_API_KEY=your_tavily_api_key_here

# -----------------------------------------------------------------
# 4. Monitoring & Tracing (LangSmith)
# -----------------------------------------------------------------

# Set to 'true' to enable tracing to LangSmith.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT="Emei-Master-Agent"

# -----------------------------------------------------------------
# 5. Miscellaneous
# -----------------------------------------------------------------

# (Optional) Timeout for API requests in seconds.
# TIMEOUT=30
